{
  "expo": {
    "name": "Bagdrop",
    "slug": "bagdrop-mobile",
    "scheme": "bagdrop",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#080F1E",
    "assetBundlePatterns": ["**/*"],
    "icon": "./assets/logo.png",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "co.bagdrop.mobile",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use Face ID to sign in to your Bagdrop account quickly."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#FFFFFF"
      },
      "package": "co.bagdrop.mobile",
      "permissions": ["USE_BIOMETRIC", "USE_FINGERPRINT", "NOTIFICATIONS"]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "color": "#FF6300"
        }
      ]
    ],
    "extra": {
      "apiBaseUrl": "https://bagdrop.co",
      "supabaseUrl": "https://lfxvyleqzddunbplmruv.supabase.co",
      "supabaseAnonKey": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImxmeHZ5bGVxemRkdW5icGxtcnV2Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODE0OTc3MTksImV4cCI6MjA5NzA3MzcxOX0.uKglBaMNM5Nj0bGwzqkFOXWjix-MfQ5kGyvgAiQBDUA",
      "razorpayKeyId": "YOUR_RAZORPAY_KEY_ID_HERE",
      "router": {
        "origin": false
      }
    }
  }
}

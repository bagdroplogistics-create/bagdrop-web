# ─────────────────────────────────────────────────────────────
# BAGDROP — Environment Variables
# Copy to .env.local and fill in real values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
# Get from: https://supabase.com/dashboard → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here   # NEVER expose to client

# ── Razorpay ──────────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com → Settings → API Keys
# Use TEST keys during development (prefix: rzp_test_)
# Use LIVE keys in production (prefix: rzp_live_)
RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID
RAZORPAY_KEY_SECRET=your_razorpay_secret_here
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_YOUR_KEY_ID   # Same as above — safe to expose

# ── Google Maps ───────────────────────────────────────────────
# Get from: https://console.cloud.google.com → APIs → Maps JavaScript API
# Restrict to: your domain + localhost
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_key_here

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000   # Change to https://bagdrop.co in production

# ── Resend (transactional email) ──────────────────────────────
# Get from: https://resend.com/api-keys  (free tier: 100 emails/day)
# Verify sending domain at: https://resend.com/domains → add bagdrop.co
# Without this key, emails are skipped silently — bookings still work.
RESEND_API_KEY=re_jEGqXYrB_BPdHtdjriCo7nXo4VgyZigUe
